@model XYDataLabs.OrderProcessingSystem.UI.Models.PaymentCallbackViewModel
@{
    ViewData["Title"] = "Payment Callback";
    var normalizedStatus = (Model.Status ?? "unknown").ToLowerInvariant();
    var alertClass = normalizedStatus switch
    {
        "completed" => "success",
        "charge_pending" => "warning",
        "failed" => "danger",
        "cancelled" => "secondary",
        _ => "info"
    };
    var heading = normalizedStatus switch
    {
        "completed" => "Payment Completed",
        "charge_pending" => "Payment Pending 3D Secure Confirmation",
        "failed" => "Payment Failed",
        "cancelled" => "Payment Cancelled",
        _ => "Payment Callback Received"
    };
    var callbackRequestJson = System.Text.Json.JsonSerializer.Serialize(new
    {
        orderId = Model.OrderId,
        callbackStatus = Model.Status,
        errorMessage = Model.ErrorMessage,
        callbackParameters = Model.Parameters
    });
    var apiBaseUrlJson = System.Text.Json.JsonSerializer.Serialize((ViewData["ApiBaseUrl"]?.ToString() ?? string.Empty).TrimEnd('/'));
    var paymentIdJson = System.Text.Json.JsonSerializer.Serialize(Model.PaymentId);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-@alertClass text-white">
                    <h4 class="mb-0">@heading</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-@alertClass mb-4" role="alert">
                        <strong>Status:</strong> @Model.Status
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="mt-2">@Model.ErrorMessage</div>
                        }
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Payment Id</dt>
                        <dd class="col-sm-9">@(Model.PaymentId ?? "Not provided")</dd>

                        <dt class="col-sm-3">Order Id</dt>
                        <dd class="col-sm-9">@(Model.OrderId ?? "Not provided")</dd>
                    </dl>

                    <div id="backend-status-panel" class="alert alert-info" role="status">
                        Confirming final status with backend...
                    </div>

                    <dl class="row" id="backend-status-details" hidden>
                        <dt class="col-sm-3">Confirmed Status</dt>
                        <dd class="col-sm-9" id="backend-status-value">Pending</dd>

                        <dt class="col-sm-3">Source</dt>
                        <dd class="col-sm-9" id="backend-status-source">Pending</dd>

                        <dt class="col-sm-3">Message</dt>
                        <dd class="col-sm-9" id="backend-status-message">Pending</dd>

                        <dt class="col-sm-3">Reference</dt>
                        <dd class="col-sm-9" id="backend-status-reference">Not provided</dd>
                    </dl>

                    @if (Model.Parameters.Count > 0)
                    {
                        <h5 class="mt-4">Callback Parameters</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Key</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var parameter in Model.Parameters.OrderBy(item => item.Key, StringComparer.OrdinalIgnoreCase))
                                {
                                    <tr>
                                        <td>@parameter.Key</td>
                                        <td>@parameter.Value</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">OpenPay returned to the application without query parameters.</p>
                    }

                    <div class="mt-4 d-flex gap-2">
                        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Return to payment page</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const apiBaseUrl = @Html.Raw(apiBaseUrlJson);
            const paymentId = @Html.Raw(paymentIdJson);
            const callbackRequest = @Html.Raw(callbackRequestJson);
            const panel = document.getElementById('backend-status-panel');
            const details = document.getElementById('backend-status-details');
            const statusValue = document.getElementById('backend-status-value');
            const statusSource = document.getElementById('backend-status-source');
            const statusMessage = document.getElementById('backend-status-message');
            const statusReference = document.getElementById('backend-status-reference');

            const alertClassByCategory = {
                success: 'alert-success',
                warning: 'alert-warning',
                danger: 'alert-danger',
                secondary: 'alert-secondary',
                info: 'alert-info'
            };

            if (!paymentId || !apiBaseUrl) {
                panel.textContent = 'The callback was received, but the payment cannot be confirmed because the payment id or API base URL is missing.';
                panel.className = 'alert alert-warning';
                return;
            }

            fetch(`${apiBaseUrl}/api/v1/payments/${encodeURIComponent(paymentId)}/confirm-status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(callbackRequest)
            })
                .then(async response => {
                    const contentType = response.headers.get('content-type') || '';
                    const payload = contentType.includes('application/json')
                        ? await response.json()
                        : null;

                    if (!response.ok || !payload?.success || !payload?.data) {
                        throw new Error(payload?.message || `Status confirmation failed with HTTP ${response.status}.`);
                    }

                    return payload.data;
                })
                .then(data => {
                    panel.textContent = data.statusMessage;
                    panel.className = `alert ${alertClassByCategory[data.statusCategory] || 'alert-info'}`;

                    statusValue.textContent = data.status;
                    statusSource.textContent = data.remoteStatusConfirmed
                        ? 'OpenPay remote confirmation + local persistence updated'
                        : 'Local persistence only';
                    statusMessage.textContent = data.errorMessage || data.statusMessage;
                    statusReference.textContent = data.transactionReferenceId || 'Not provided';
                    details.hidden = false;
                })
                .catch(error => {
                    console.error('Error confirming payment callback status:', error);
                    panel.textContent = error.message || 'An error occurred while confirming the payment status.';
                    panel.className = 'alert alert-danger';
                });
        })();
    </script>
}