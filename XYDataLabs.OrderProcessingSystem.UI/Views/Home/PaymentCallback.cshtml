@model XYDataLabs.OrderProcessingSystem.UI.Models.PaymentCallbackViewModel
@{
    ViewData["Title"] = "Payment Callback";
    var attemptOrderIdJson = System.Text.Json.JsonSerializer.Serialize(ViewData["AttemptOrderId"]?.ToString());
    var callbackRequestTemplateJson = System.Text.Json.JsonSerializer.Serialize(new
    {
        attemptOrderId = ViewData["AttemptOrderId"]?.ToString(),
        callbackStatus = Model.Status,
        errorMessage = Model.ErrorMessage,
        callbackParameters = Model.Parameters
    });
    var apiBaseUrlJson = System.Text.Json.JsonSerializer.Serialize((ViewData["ApiBaseUrl"]?.ToString() ?? string.Empty).TrimEnd('/'));
    var paymentIdJson = System.Text.Json.JsonSerializer.Serialize(Model.PaymentId);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div id="callback-header" class="card-header bg-info text-white">
                    <h4 id="callback-heading" class="mb-0">Payment Callback Received</h4>
                </div>
                <div class="card-body">
                    <div id="callback-status-banner" class="alert alert-info mb-4" role="alert">
                        <strong>Final Status:</strong> Confirming...
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="mt-2">@Model.ErrorMessage</div>
                        }
                        else
                        {
                            <div class="mt-2">Confirming final payment status with the backend.</div>
                        }
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Payment Id</dt>
                        <dd class="col-sm-9">@(Model.PaymentId ?? "Not provided")</dd>

                        <dt class="col-sm-3">Customer Order Id</dt>
                        <dd id="callback-customer-order-id" class="col-sm-9">Pending confirmation</dd>

                        <dt class="col-sm-3">Status Source</dt>
                        <dd class="col-sm-9" id="backend-status-source-inline">Pending</dd>
                    </dl>

                    <details class="mt-4">
                        <summary class="fw-semibold">Technical Details</summary>

                        <dl class="row mt-3 mb-0">
                            <dt class="col-sm-3">3D Secure Stage</dt>
                            <dd id="callback-3ds-stage" class="col-sm-9">Pending</dd>

                            <dt class="col-sm-3">Confirmed Status</dt>
                            <dd class="col-sm-9" id="backend-status-value">Pending</dd>

                            <dt class="col-sm-3">Source</dt>
                            <dd class="col-sm-9" id="backend-status-source">Pending</dd>

                            <dt class="col-sm-3">Message</dt>
                            <dd class="col-sm-9" id="backend-status-message">Pending</dd>

                            <dt class="col-sm-3">Reference</dt>
                            <dd class="col-sm-9" id="backend-status-reference">Not provided</dd>
                        </dl>

                        @if (Model.Parameters.Count > 0)
                        {
                        <h5 class="mt-4">Callback Parameters</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Key</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var parameter in Model.Parameters.OrderBy(item => item.Key, StringComparer.OrdinalIgnoreCase))
                                {
                                    <tr>
                                        <td>@parameter.Key</td>
                                        <td>@parameter.Value</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        }
                        else
                        {
                        <p class="text-muted">OpenPay returned to the application without query parameters.</p>
                        }
                    </details>

                    <div class="mt-4 d-flex gap-2">
                        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Return to payment page</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const apiBaseUrl = @Html.Raw(apiBaseUrlJson);
            const paymentId = @Html.Raw(paymentIdJson);
            const attemptOrderId = @Html.Raw(attemptOrderIdJson);
            const callbackRequestTemplate = @Html.Raw(callbackRequestTemplateJson);
            const pendingPaymentStorageKeyPrefix = 'pending-payment:';
            const header = document.getElementById('callback-header');
            const heading = document.getElementById('callback-heading');
            const banner = document.getElementById('callback-status-banner');
            const customerOrderId = document.getElementById('callback-customer-order-id');
            const threeDSecureStage = document.getElementById('callback-3ds-stage');
            const inlineStatusSource = document.getElementById('backend-status-source-inline');
            const statusValue = document.getElementById('backend-status-value');
            const statusSource = document.getElementById('backend-status-source');
            const statusMessage = document.getElementById('backend-status-message');
            const statusReference = document.getElementById('backend-status-reference');
            const headerClassByCategory = {
                success: 'bg-success text-white',
                warning: 'bg-warning text-dark',
                danger: 'bg-danger text-white',
                secondary: 'bg-secondary text-white',
                info: 'bg-info text-white'
            };

            const alertClassByCategory = {
                success: 'alert-success',
                warning: 'alert-warning',
                danger: 'alert-danger',
                secondary: 'alert-secondary',
                info: 'alert-info'
            };

            const headingByCategory = {
                success: 'Payment Completed',
                warning: 'Payment Pending Confirmation',
                danger: 'Payment Failed',
                secondary: 'Payment Cancelled',
                info: 'Payment Callback Received'
            };

            const getStoredPendingPaymentContext = currentPaymentId => {
                if (!currentPaymentId) {
                    return null;
                }

                try {
                    const rawValue = sessionStorage.getItem(`${pendingPaymentStorageKeyPrefix}${currentPaymentId}`);
                    return rawValue ? JSON.parse(rawValue) : null;
                } catch (error) {
                    console.warn('Unable to read stored pending payment context.', error);
                    return null;
                }
            };

            const clearStoredPendingPaymentContext = currentPaymentId => {
                if (!currentPaymentId) {
                    return;
                }

                try {
                    sessionStorage.removeItem(`${pendingPaymentStorageKeyPrefix}${currentPaymentId}`);
                } catch (error) {
                    console.warn('Unable to clear stored pending payment context.', error);
                }
            };

            const toDisplayText = value => {
                if (!value) {
                    return 'Unknown';
                }

                return value
                    .toString()
                    .split('_')
                    .filter(part => part)
                    .map(part => part.charAt(0).toUpperCase() + part.slice(1).toLowerCase())
                    .join(' ');
            };

            const pendingPaymentContext = getStoredPendingPaymentContext(paymentId);
            const resolvedAttemptOrderId = attemptOrderId || pendingPaymentContext?.attemptOrderId || null;
            const callbackRequest = {
                ...callbackRequestTemplate,
                attemptOrderId: resolvedAttemptOrderId
            };

            if (!paymentId || !apiBaseUrl) {
                banner.textContent = 'The callback was received, but the payment cannot be confirmed because the payment id or API base URL is missing.';
                banner.className = 'alert alert-warning mb-4';
                return;
            }

            const getTenantRuntime = () => {
                if (!window.OrderProcessingTenant) {
                    return Promise.reject(new Error('Tenant bootstrap script is unavailable.'));
                }

                return window.OrderProcessingTenant.ready();
            };

            getTenantRuntime()
                .then(runtimeConfiguration => fetch(`${apiBaseUrl}/api/v1/payments/${encodeURIComponent(paymentId)}/confirm-status`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        [window.OrderProcessingTenant?.getTenantHeaderName() || runtimeConfiguration.tenantHeaderName || 'X-Tenant-Code']:
                            window.OrderProcessingTenant?.getSelectedTenantCode() || runtimeConfiguration.activeTenantCode
                    },
                    body: JSON.stringify(callbackRequest)
                }))
                .then(async response => {
                    const contentType = response.headers.get('content-type') || '';
                    const payload = contentType.includes('application/json')
                        ? await response.json()
                        : null;

                    if (!response.ok || !payload?.success || !payload?.data) {
                        throw new Error(payload?.message || `Status confirmation failed with HTTP ${response.status}.`);
                    }

                    return payload.data;
                })
                .then(data => {
                    clearStoredPendingPaymentContext(paymentId);

                    header.className = `card-header ${headerClassByCategory[data.statusCategory] || 'bg-info text-white'}`;
                    heading.textContent = headingByCategory[data.statusCategory] || 'Payment Callback Received';

                    banner.className = `alert ${alertClassByCategory[data.statusCategory] || 'alert-info'} mb-4`;
                    banner.innerHTML = `<strong>Final Status:</strong> ${toDisplayText(data.status)}<div class="mt-2">${data.errorMessage || data.statusMessage}</div>`;

                    customerOrderId.textContent = data.customerOrderId || 'Not provided';
                    threeDSecureStage.textContent = toDisplayText(data.threeDSecureStage);
                    statusValue.textContent = toDisplayText(data.status);
                    statusSource.textContent = data.remoteStatusConfirmed
                        ? 'OpenPay confirmed and local records updated'
                        : 'Local records only';
                    inlineStatusSource.textContent = statusSource.textContent;
                    statusMessage.textContent = data.errorMessage || data.statusMessage;
                    statusReference.textContent = data.transactionReferenceId || 'Not provided';
                })
                .catch(error => {
                    console.error('Error confirming payment callback status:', error);
                    banner.textContent = error.message || 'An error occurred while confirming the payment status.';
                    banner.className = 'alert alert-danger mb-4';
                });
        })();
    </script>
}