{
  "openapi": "3.0.1",
  "info": {
    "title": "OrderProcessingSystem API - DEV Environment",
    "description": "OrderProcessingSystem API with Customer, Order endpoints running in DEV environment [Local] | Active Tenant: TenantA",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:5010",
      "description": "DEV Server"
    }
  ],
  "paths": {
    "/api/v1/Audit/{entityName}/{entityId}": {
      "get": {
        "tags": [
          "Audit"
        ],
        "parameters": [
          {
            "name": "entityName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Customer/GetAllCustomers": {
      "get": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to retrieve all customers",
        "description": "Retrieve all customers.",
        "operationId": "GetAllCustomers",
        "responses": {
          "200": {
            "description": "Returns all customers"
          }
        }
      }
    },
    "/api/v1/Customer/GetAllCustomersByName": {
      "get": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to search customers by name with pagination.",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Customer name to search for.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Page size for pagination.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Customer/{id}": {
      "get": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to retrieve a specific customer and their orders",
        "operationId": "GetCustomerById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CustomerId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to update an existing customer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CustomerId"
            }
          }
        ],
        "requestBody": {
          "description": "customer",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCustomerRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCustomerRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCustomerRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to delete an existing customer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Customer id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CustomerId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Customer": {
      "post": {
        "tags": [
          "Customer"
        ],
        "summary": "Endpoint to create a new customer",
        "requestBody": {
          "description": "customer",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Info/environment": {
      "get": {
        "tags": [
          "Info"
        ],
        "summary": "Gets the current environment and deployment information",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { }
              },
              "application/json": {
                "schema": { }
              },
              "text/json": {
                "schema": { }
              }
            }
          }
        }
      }
    },
    "/api/v1/Info/runtime-configuration": {
      "get": {
        "tags": [
          "Info"
        ],
        "summary": "Gets non-sensitive runtime configuration required for UI bootstrap.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/v1/Order": {
      "post": {
        "tags": [
          "Order"
        ],
        "summary": "Endpoint to Create order for a customer",
        "description": "Create order.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create order"
          }
        }
      }
    },
    "/api/v1/Order/{id}": {
      "get": {
        "tags": [
          "Order"
        ],
        "summary": "Endpoint to retrieve details for a specific order, including the total price",
        "operationId": "GetOrderDetailsById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Order id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/OrderId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Payments/ProcessPayment": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Creates a new customer, adds a card, and processes a payment in a single operation",
        "requestBody": {
          "description": "CustomerWithCardPaymentRequestDto",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerWithCardPaymentRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerWithCardPaymentRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerWithCardPaymentRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Payments/{paymentId}/confirm-status": {
      "post": {
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentStatusLookupRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentStatusLookupRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentStatusLookupRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/payment/client-event": {
      "post": {
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentClientEventRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentClientEventRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentClientEventRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/Product/GetAllProducts": {
      "get": {
        "tags": [
          "Product"
        ],
        "summary": "Endpoint to retrieve all products.",
        "operationId": "GetAllProducts",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AvailableTenantConfiguration": {
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "integer",
            "format": "int32"
          },
          "tenantCode": {
            "type": "string",
            "nullable": true
          },
          "tenantName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateCustomerRequestDto": {
        "required": [
          "email",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateOrderRequestDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "integer",
            "format": "int32"
          },
          "productIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CustomerId": {
        "type": "object",
        "properties": {
          "value": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CustomerWithCardPaymentRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "deviceSessionId": {
            "type": "string",
            "nullable": true
          },
          "cardNumber": {
            "type": "string",
            "nullable": true
          },
          "expirationYear": {
            "type": "string",
            "nullable": true
          },
          "expirationMonth": {
            "type": "string",
            "nullable": true
          },
          "cvv2": {
            "type": "string",
            "nullable": true
          },
          "customerOrderId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "OrderId": {
        "type": "object",
        "properties": {
          "value": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PaymentClientEventRequest": {
        "type": "object",
        "properties": {
          "eventName": {
            "type": "string",
            "nullable": true
          },
          "severity": {
            "type": "string",
            "nullable": true
          },
          "tenantCode": {
            "type": "string",
            "nullable": true
          },
          "clientFlowId": {
            "type": "string",
            "nullable": true
          },
          "customerOrderId": {
            "type": "string",
            "nullable": true
          },
          "attemptOrderId": {
            "type": "string",
            "nullable": true
          },
          "paymentId": {
            "type": "string",
            "nullable": true
          },
          "paymentStatus": {
            "type": "string",
            "nullable": true
          },
          "statusCategory": {
            "type": "string",
            "nullable": true
          },
          "httpStatus": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "errorCode": {
            "type": "string",
            "nullable": true
          },
          "errorMessage": {
            "type": "string",
            "nullable": true
          },
          "pagePath": {
            "type": "string",
            "nullable": true
          },
          "clientTimestampUtc": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PaymentStatusLookupRequestDto": {
        "type": "object",
        "properties": {
          "attemptOrderId": {
            "type": "string",
            "nullable": true
          },
          "callbackStatus": {
            "type": "string",
            "nullable": true
          },
          "errorMessage": {
            "type": "string",
            "nullable": true
          },
          "callbackParameters": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RuntimeConfigurationResponse": {
        "type": "object",
        "properties": {
          "activeTenantCode": {
            "type": "string",
            "nullable": true
          },
          "configuredActiveTenantCode": {
            "type": "string",
            "nullable": true
          },
          "tenantHeaderName": {
            "type": "string",
            "nullable": true
          },
          "availableTenants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AvailableTenantConfiguration"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateCustomerRequestDto": {
        "required": [
          "email",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}