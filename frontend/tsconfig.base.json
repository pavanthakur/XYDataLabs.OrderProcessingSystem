{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "paths": {
      "@xydatalabs/orderprocessing-api-sdk": [
        "packages/api-sdk/src/index.ts"
      ],
      "@xydatalabs/orderprocessing-tenant-session": [
        "packages/tenant-session/src/index.ts"
      ]
    }
  }
}