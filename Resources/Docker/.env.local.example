# Copy this file to .env.local on your machine and set local-only Docker secrets.
# The real .env.local file is gitignored.
LOCAL_SQL_PASSWORD=<set-a-local-docker-sql-password>
LOCAL_CERT_PASSWORD=<set-a-local-https-certificate-password>
LOCAL_OPENPAY_MERCHANT_ID=<set-a-local-openpay-merchant-id>
LOCAL_OPENPAY_PRIVATE_KEY=<set-a-local-openpay-private-key>
LOCAL_OPENPAY_DEVICE_SESSION_ID=<set-a-local-openpay-device-session-id>